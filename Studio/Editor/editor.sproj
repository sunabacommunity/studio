{
    "name": "Sunaba Studio",
    "version": "1.0",
    "type": "executable",
    "rootUrl": "studio://",
    "assetsdir": "assets",
    "scriptdir": "src",
    "apisymbols": true,
    "sourcemap": true,
    "entrypoint": "EditorMain",
    "luabin": "main",
    "libraries": [],
    "compilerFlags": [
        "-D absolute-path",
        "--library gamepak",
        "-dce std",
        "--macro addClassPath('../common')"
    ]
}