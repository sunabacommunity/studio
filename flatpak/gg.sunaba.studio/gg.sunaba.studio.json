{
  "app-id": "gg.sunaba.studio",
  "runtime": "org.freedesktop.Platform",
  "runtime-version": "25.08",
  "sdk": "org.freedesktop.Sdk",
  "command": "sunaba-studio",
  "finish-args": [
    "--share=network",
    "--socket=x11",
    "--socket=wayland",
    "--device=dri",
    "--filesystem=host"
  ],
  "modules": [
    {
      "name": "sunaba-studio",
      "buildsystem": "simple",
      "build-commands": [
        "mkdir -p ${FLATPAK_DEST}/bin",
        "cp -r * ${FLATPAK_DEST}/bin",
        "chmod +x ${FLATPAK_DEST}/bin/data_Sunaba.Studio_linuxbsd_x86_64/toolchain/linux-x86_64/haxe",
        "chmod +x ${FLATPAK_DEST}/bin/data_Sunaba.Studio_linuxbsd_x86_64/toolchain/linux-x86_64/haxelib",
        "chmod +x ${FLATPAK_DEST}/bin/data_Sunaba.Studio_linuxbsd_x86_64/toolchain/linux-x86_64/neko"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "app/"
        }
      ]
    }
  ]
}